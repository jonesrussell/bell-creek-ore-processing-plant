    "@typescript-eslint/eslint-plugin": "^4.5.0",
    "@typescript-eslint/parser": "^4.5.0",
    "chai": "^4.2.0",
    "copy-webpack-plugin": "^6.2.1",
    "dart-sass": "^1.25.0",
    "eslint": "^7.12.0",
    "mocha": "^7.1.2",
    "serve-static": "^1.14.1",
    "ts-loader": "^8.0.7",
    "typescript": "^4.0.3",
    "webpack": "^5.2.0",
    "webpack-cli": "^4.1.0",
    "webpack-dev-server": "^3.11.0"
